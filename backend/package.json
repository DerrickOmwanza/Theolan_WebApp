{
  "name": "olanallumint-backend",
  "version": "1.0.0",
  "description": "Theolan Aluminium International Ltd - Backend API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/nodemon/bin/nodemon.js src/server.js",
    "start": "node src/server.js",
    "setup-db": "node scripts/setup-db.js",
    "migrate:latest": "node node_modules/knex/bin/cli.js migrate:latest",
    "migrate:rollback": "node node_modules/knex/bin/cli.js migrate:rollback",
    "migrate:make": "node node_modules/knex/bin/cli.js migrate:make",
    "seed:run": "node node_modules/knex/bin/cli.js seed:run",
    "seed:make": "node node_modules/knex/bin/cli.js seed:make",
    "db:reset": "node node_modules/knex/bin/cli.js migrate:rollback --all && node node_modules/knex/bin/cli.js migrate:latest && node node_modules/knex/bin/cli.js seed:run",
    "lint": "node node_modules/eslint/bin/eslint.js src --ext .js,.jsx",
    "lint:fix": "node node_modules/eslint/bin/eslint.js src --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "keywords": [
    "aluminium",
    "fabrication",
    "booking",
    "order-management",
    "nairobi",
    "kenya"
  ],
  "author": "Theolan Aluminium International Ltd",
  "license": "PROPRIETARY",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.10.0",
    "knex": "^3.1.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "9.0.2",
    "joi": "^17.11.0",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "axios": "^1.6.5",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "cloudinary": "^1.40.0",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.54.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "supertest": "^6.3.3",
    "jest-extended": "^4.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
